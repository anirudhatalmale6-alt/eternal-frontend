# Public WordPress API URL (used for client-side requests)
NEXT_PUBLIC_WP_API_URL=https://www.eternalorganizer.com/wp-json

# Internal WordPress API URL (used for server-side requests when running on same server)
# When deployed on the server, set this to the internal Docker network URL
# WP_INTERNAL_API_URL=http://wp_openresty/wp-json
